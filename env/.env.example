############################################################
# GitHub Container Registry (GHCR)
############################################################

GHCR_REGISTRY=ghcr.io

GHCR_USERNAME=khalid-786

# Personal Access Token (PAT)
GHCR_TOKEN=

############################################################
# Docker Images
############################################################

BACKEND_IMAGE=ghcr.io/your-github-username/msar-api:v1.0.0

FRONTEND_IMAGE=ghcr.io/your-github-username/msar-frontend:v1.0.0

############################################################
# SQL Server
############################################################

SA_PASSWORD=YourStrongPassword123!

############################################################
# ASP.NET
############################################################

ASPNETCORE_ENVIRONMENT=Production

############################################################
# Application
############################################################

APP_PORT=5080

FRONTEND_PORT=80

############################################################
# RabbitMQ
############################################################

RABBITMQ_HOST=msar-rabbit

RABBITMQ_USER=guest

RABBITMQ_PASSWORD=guest

############################################################
# Health Checks
############################################################

API_HEALTH_URL=http://localhost:5080/health

FRONTEND_HEALTH_URL=http://localhost

############################################################
# Deployment
############################################################

DEPLOY_TIMEOUT=300

HEALTH_RETRIES=30

HEALTH_DELAY=5

############################################################
# Rollback
############################################################

KEEP_BACKUPS=10

############################################################
# Logging
############################################################

LOG_LEVEL=INFO